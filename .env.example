# SeyalRun v2.0 — environment configuration.
#
# Copy to .env (git-ignored) and fill in real values. Every secret here is
# required — services fail fast at startup if a required var is missing.
# Never commit .env, never hardcode any of these values in source.

# ── Database ────────────────────────────────────────────────────────────
# Single engine for the whole stack — choose ONE option and set DB_HOST
# accordingly. Do NOT mix options.
#
# Option A — Shared Zabbix DB server (no extra container):
#   DB_HOST=192.168.64.8   (your Zabbix server IP)
#   DB_PORT=5432
#   DB_SSLMODE=require
#   (run ops/init-db.sh to create seyalrun_* databases on that server)
#
# Option B — Dedicated separate DB server:
#   DB_HOST=<your dedicated postgres/mysql host>
#   DB_PORT=5432
#   DB_SSLMODE=require
#   (run ops/init-db.sh against that server)
#
# Option C — Containerized (default for staging / local dev):
#   DB_HOST=postgres        (service name in docker-compose.db.yml)
#   DB_SSLMODE=disable      (container-local, no TLS needed)
#   docker compose -f docker-compose.yml -f docker-compose.db.yml \
#     --profile postgres-db up -d
#
DB_ENGINE=postgres            # postgres|mysql
DB_HOST=postgres              # see options above
DB_PORT=5432                  # 5432 for postgres, 3306 for mysql
DB_USER=seyalrun
DB_PASSWORD=
DB_SSLMODE=disable            # disable|require|verify-full (postgres) / disable|required (mysql)
IDENTITY_DB_NAME=seyalrun_identity
INVENTORY_DB_NAME=seyalrun_inventory
TERMINAL_DB_NAME=seyalrun_terminal

# ── Redis (api-gateway rate limiting) ──────────────────────────────────
REDIS_URL=redis://redis:6379/0   # use rediss:// for TLS if Redis isn't co-located

# ── Auth / tokens ───────────────────────────────────────────────────────
# Client sessions are opaque, server-side (Redis) — not a JWT the browser can
# decode. JWT_SECRET/JWT_ALGORITHM below sign only the short-lived Zabbix
# link-token and MFA credential-reveal token (identity-service internal use).
JWT_SECRET=                      # link-token / credential-reveal token signing key (identity-service)
JWT_ALGORITHM=HS256
SESSION_IDLE_MINUTES=30          # session dies if idle this long (identity-service + api-gateway)
SESSION_ABSOLUTE_HOURS=8         # session dies at this age regardless of activity (api-gateway)
SERVICE_JWT_SECRET=              # service-to-service token signing key (all services)
API_TOKEN_PEPPER=                # extra pepper for hashing Personal Access Tokens (identity-service)

# ── Credential vault (inventory-service) ───────────────────────────────
ZA_VAULT_PASSWORD=               # AES-256-GCM credential encryption master key (>=32 chars)
ZA_VAULT_SALT=                   # generate once: openssl rand -hex 16

# SSH host-key verification for outbound connections (terminal + automation).
# Empty = no verification (logs a warning). Set to a known_hosts file path to
# enforce strict host-key checking and mitigate MITM on SSH to managed hosts.
SSH_KNOWN_HOSTS_PATH=

# ── Zabbix integration ──────────────────────────────────────────────────
ZABBIX_API_URL=
ZABBIX_API_TOKEN=
ZABBIX_WEBHOOK_HMAC_SECRET=       # REQUIRED — HMAC key for the /webhook/zabbix receiver.
                                  # The webhook bypasses the api-gateway, so this is its ONLY
                                  # auth; zabbix-integration-service refuses to start if unset.
                                  # Generate: openssl rand -hex 32

# Zabbix module (zabbix-module/seyalrun/ — embeds SeyalRun's menu + settings inside
# Zabbix). Only needed if that module is installed; leave blank otherwise, in which
# case /auth/zbx-sso-init just 503s. MUST match module_secret in the Zabbix module's
# own config.php exactly. Generate: openssl rand -hex 32
ZABBIX_MODULE_SECRET=

# ── api-gateway ──────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://localhost
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── edge-proxy (TLS termination, the only host-published service) ─────────
TLS_CERT_PATH=                   # path on host to TLS cert (Let's Encrypt or internal CA)
TLS_KEY_PATH=                    # path on host to TLS key
EDGE_HTTP_PORT=8080
EDGE_HTTPS_PORT=8443
# CSP frame-ancestors EXTRA origins. The header is always `frame-ancestors 'self' <this>`,
# so leave blank for same-origin-only (no external embedding). To embed in Zabbix, set to
# the Zabbix origin as an unquoted host source, e.g. https://zabbix.example.com.
# NEVER set to "*" — that lets any site frame the PAM console (clickjacking).
FRAME_ANCESTORS=

# ── Self-monitoring (agentless, HTTP) ──────────────────────────────────────
# Zabbix polls GET https://<edge-host>:<EDGE_HTTPS_PORT>/webhook/zabbix/monitor
# with header X-Monitor-Token: <ZABBIX_WEBHOOK_HMAC_SECRET>. Set the template
# macros {$SEYALRUN.MONITOR.URL} and {$SEYALRUN.MONITOR.TOKEN} accordingly —
# no zabbix-agent sidecar and no extra env vars are needed.

# ── Identity seed ───────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=Admin
# The seeded password is ALWAYS the default "seyalrun" (not configurable);
# first login REQUIRES a password change before anything else works.

# ── Housekeeping / retention ───────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=180
RECORDING_RETENTION_DAYS=90

# ── terminal-service / recording-service ──────────────────────────────────────
# Max frames retained per session recording in memory (oldest dropped first)
TERMINAL_RECORDING_MAX_FRAMES=20000
# Seconds between command-filter/login-ACL cache refreshes in active sessions
TERMINAL_POLICY_REFRESH_SECONDS=60

# ── automation-service / zabbix-integration-service ────────────────────────
AUTOMATION_DB_NAME=seyalrun_automation

# ZABBIX_WEBHOOK_HMAC_SECRET — already reserved above; now consumed by zabbix-integration-service.
# ZABBIX_API_URL / ZABBIX_API_TOKEN — already reserved above; now consumed for event.acknowledge.
ZABBIX_CONSOLE_URL=              # e.g. https://zabbix.example.com — included in result messages

# Maximum wall-clock time per job run
JOB_EXEC_TIMEOUT_SECONDS=3600
# output_lines cap per job run (oldest lines dropped when exceeded)
MAX_OUTPUT_LINES=500

# ── v1.1: password strength / rotation (Features 9, 10) ────────────────────
WEAK_CREDENTIAL_THRESHOLD=2        # zxcvbn score below this = weak
ROTATION_DEFAULT_DAYS=90

# ── v1.1: recording tiering (Feature 4) ────────────────────────────────────
RECORDING_TIER_AFTER_DAYS=7        # move local recordings to S3 after N days

# ── v1.1: centralized log backend (Feature 1) ──────────────────────────────
# Backend + secrets are managed at runtime in Admin → Log Backend (stored
# vault-encrypted in the DB). These are optional fallbacks/consumed by the
# automation housekeeping ES-rollover job only.
ES_URL=
ES_INDEX_PREFIX=seyalrun
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=                   # for MinIO/compatible; blank for AWS

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
