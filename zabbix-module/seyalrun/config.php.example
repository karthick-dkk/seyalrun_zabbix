<?php declare(strict_types = 1);

/**
 * SeyalRun <-> Zabbix module configuration.
 *
 * Copy this file to config.php (same directory) and fill in the values for your
 * deployment:
 *
 *     cp config.php.example config.php
 *
 * config.php is listed in .gitignore for this module on purpose — never commit
 * real secrets. module_secret here MUST match ZABBIX_MODULE_SECRET in
 * SeyalRun's own .env exactly, on both sides (see zabbix-module/README.md).
 *
 * (A future version may move this into Zabbix's own module-configuration UI —
 * a plain file is deliberately used here so behavior doesn't depend on
 * Zabbix-version-specific module-config storage APIs.)
 */
return [
	// SeyalRun's base URL as reached by THIS SERVER's own PHP process (the
	// server-side curl call that mints an SSO code). On a single-host test
	// deployment this can legitimately be https://127.0.0.1:8443 — that
	// address only has to make sense from the Zabbix server's point of view.
	'seyalrun_url' => 'https://seyalrun.example.com',

	// SeyalRun's base URL as reached by the VISITOR'S BROWSER — used for the
	// iframe src and the SSH Hosts "Terminal" links. This MUST be an address
	// your browser can actually resolve and connect to, e.g. the box's real
	// IP/hostname. Optional: if omitted, falls back to seyalrun_url above —
	// only safe when that's a real hostname/IP already reachable by browsers
	// too, not a loopback address. Get this wrong and pages mint a valid SSO
	// code server-side but still render as a blank/broken iframe, because the
	// browser tries to load its OWN 127.0.0.1, not this server's.
	'seyalrun_public_url' => 'https://seyalrun.example.com',

	// Must match ZABBIX_MODULE_SECRET in SeyalRun's .env. Generate a strong random
	// value once, e.g.: openssl rand -hex 32
	'module_secret' => '',

	// Verify SeyalRun's TLS certificate on the server-side SSO call. Only set this
	// to false temporarily against a self-signed cert while testing — never in production.
	'verify_tls' => true,
];
